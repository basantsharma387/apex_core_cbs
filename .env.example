# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/banking_dev
DATABASE_URL_SHADOW=postgresql://postgres:password@localhost:5432/banking_shadow

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=apex-banking-platform
KAFKA_GROUP_ID=apex-consumer-group

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-64-char-random-hex-string-access-token-secret-here
JWT_REFRESH_SECRET=replace-with-64-char-random-hex-string-refresh-token-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Services (internal) ───────────────────────────────────────────────────────
GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://localhost:3001
LOAN_SERVICE_URL=http://localhost:3002
EWS_SERVICE_URL=http://localhost:3003
AML_SERVICE_URL=http://localhost:3004
DMS_SERVICE_URL=http://localhost:3005
CMS_SERVICE_URL=http://localhost:3006
IFRS9_SERVICE_URL=http://localhost:3007
ALM_SERVICE_URL=http://localhost:3008
NOTIFICATION_SERVICE_URL=http://localhost:3009
REPORT_SERVICE_URL=http://localhost:3010
DWH_SERVICE_URL=http://localhost:3011

AUTH_SERVICE_PORT=3001
LOAN_SERVICE_PORT=3002
EWS_SERVICE_PORT=3003
AML_SERVICE_PORT=3004
DMS_SERVICE_PORT=3005
CMS_SERVICE_PORT=3006
IFRS9_SERVICE_PORT=3007
ALM_SERVICE_PORT=3008
NOTIFICATION_SERVICE_PORT=3009
REPORT_SERVICE_PORT=3010
DWH_SERVICE_PORT=3011

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api/v1
VITE_APP_NAME=Data Networks Banking Platform
VITE_PORTAL_NAME=Data Networks

# ── Azure (production) ────────────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=documents
AZURE_KEY_VAULT_URL=
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
BCRYPT_ROUNDS=12
